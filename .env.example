TESLA_EMAIL=you@example.com
PUSHOVER_TOKEN=your_pushover_app_token
PUSHOVER_USER=your_pushover_user_key

# How often to poll in seconds (default: 300 = 5 min)
POLL_INTERVAL=300

# Notify when battery hits this % during charging (default: 80)
TARGET_PERCENT=80

# Notify after this many minutes into a charging session (default: 240 = 4 hours)
TIMER_MINUTES=240
